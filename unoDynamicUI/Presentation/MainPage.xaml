<Page x:Class="unoDynamicUI.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      NavigationCacheMode="Required"
      Background="{ThemeResource BackgroundBrush}">
  <ScrollViewer IsTabStop="True">
    <Grid utu:SafeArea.Insets="VisibleBounds">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition />
      </Grid.RowDefinitions>
      <utu:NavigationBar Content="{Binding Title}" />

      <StackPanel Grid.Row="1"
          Margin="16"
          HorizontalAlignment="Stretch"
          Spacing="16"
          MaxWidth="920">
        <TextBlock Text="Basic navigation demo"
           FontWeight="SemiBold" />
        <TextBox Text="{Binding Name, Mode=TwoWay}"
            PlaceholderText="Enter your name:" />
        <Button Content="Go to Second Page"
            AutomationProperties.AutomationId="SecondPageButton"
            Command="{Binding GoToSecond}" />

        <TextBlock Text="Dynamic template JSON"
           FontWeight="SemiBold" />
        <TextBox Text="{Binding JsonTemplate, Mode=TwoWay}"
           AcceptsReturn="True"
           TextWrapping="Wrap"
           MinHeight="280"
           FontFamily="Consolas" />

        <StackPanel Orientation="Horizontal"
            Spacing="12">
          <Button Content="Open Dialog (From JSON)"
              Command="{Binding OpenTemplateDialog}" />
        </StackPanel>

        <TextBlock Text="{Binding BuildMessage}"
           TextWrapping="WrapWholeWords" />

        <TextBlock Text="{Binding LastAction}" />

        <TextBox Text="{Binding LastSavedValues, Mode=OneWay}"
           IsReadOnly="True"
           AcceptsReturn="True"
           TextWrapping="Wrap"
           MinHeight="120" />
      </StackPanel>
    </Grid>
  </ScrollViewer>
</Page>
